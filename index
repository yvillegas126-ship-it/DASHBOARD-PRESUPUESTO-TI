        function populateDetailFilters() {
            const selects = {
                year: el.detailFilterYear, category: el.detailFilterCategory, subcategory: el.detailFilterSubcategory,
                service: el.detailFilterService, system: el.detailFilterSystem, month: el.detailFilterMonth
            };

            Object.values(selects).forEach(sel => sel.innerHTML = '<option value="all">Todas</option>');

            state.years.forEach(y => selects.year.innerHTML += `<option value="${y}">${y}</option>`);
            const monthsSorted = ['ENERO', 'FEBRERO', 'MARZO', 'ABRIL', 'MAYO', 'JUNIO', 'JULIO', 'AGOSTO', 'SETIEMBRE', 'OCTUBRE', 'NOVIEMBRE', 'DICIEMBRE'];
            monthsSorted.forEach(m => selects.month.innerHTML += `<option value="${m}">${m.charAt(0) + m.slice(1).toLowerCase()}</option>`);

            const dataset = state.currentView === 'OPEX' ? state.rawOpex : state.rawCapex;
            const categories = new Set(), subcategories = new Set(), services = new Set(), systems = new Set();

            dataset.forEach(row => {
                if (state.currentView === 'OPEX') {
                    if (row.categoria) categories.add(row.categoria);
                    if (row.subcategoria) subcategories.add(row.subcategoria);
                    if (row.servicio) services.add(row.servicio);
                    if (row.sistema) systems.add(row.sistema);
                } else {
                    if (row.tipo) categories.add(row.tipo);
                    if (row.detalle) services.add(row.detalle);
                    if (row.ceco) subcategories.add(row.ceco);
                }
            });

            Array.from(categories).sort().forEach(c => selects.category.innerHTML += `<option value="${c}">${c}</option>`);
            Array.from(subcategories).sort().forEach(s => selects.subcategory.innerHTML += `<option value="${s}">${s}</option>`);
            Array.from(services).sort().forEach(s => selects.service.innerHTML += `<option value="${s}">${s}</option>`);
            Array.from(systems).sort().forEach(s => selects.system.innerHTML += `<option value="${s}">${s}</option>`);

            selects.year.value = detailState.selectedYear;
            selects.category.value = detailState.selectedCategory;
            selects.subcategory.value = detailState.selectedSubcategory;
            selects.service.value = detailState.selectedService;
            selects.system.value = detailState.selectedSystem;
            selects.month.value = detailState.selectedMonth;
        }

        function onDetailFilterChange() {
            detailState.selectedYear = el.detailFilterYear.value;
            detailState.selectedCategory = el.detailFilterCategory.value;
            detailState.selectedSubcategory = el.detailFilterSubcategory.value;
            detailState.selectedService = el.detailFilterService.value;
            detailState.selectedSystem = el.detailFilterSystem.value;
            detailState.selectedMonth = el.detailFilterMonth.value;
            updateDetailMatrixTable();
        }

        function clearDetailFilters() {
            detailState.selectedCategory = 'all';
            detailState.selectedSubcategory = 'all';
            detailState.selectedService = 'all';
            detailState.selectedSystem = 'all';
            detailState.selectedMonth = 'all';
            if (state.years.length > 0) detailState.selectedYear = String(state.years[state.years.length - 1]);
            
            el.detailFilterYear.value = detailState.selectedYear;
            el.detailFilterCategory.value = 'all';
            el.detailFilterSubcategory.value = 'all';
            el.detailFilterService.value = 'all';
            el.detailFilterSystem.value = 'all';
            el.detailFilterMonth.value = 'all';
            updateDetailMatrixTable();
        }

        function updateDetailMatrixTable() {
            const isPen = state.currency === 'PEN';
            const monthsSorted = ['ENERO', 'FEBRERO', 'MARZO', 'ABRIL', 'MAYO', 'JUNIO', 'JULIO', 'AGOSTO', 'SETIEMBRE', 'OCTUBRE', 'NOVIEMBRE', 'DICIEMBRE'];
            const dataset = state.currentView === 'OPEX' ? state.rawOpex : state.rawCapex;
            
            const rowsFiltered = dataset.filter(row => {
                if (detailState.selectedYear !== 'all' && String(row.year) !== detailState.selectedYear) return false;
                if (detailState.selectedMonth !== 'all' && row.mes !== detailState.selectedMonth) return false;
                
                if (state.currentView === 'OPEX') {
                    if (detailState.selectedCategory !== 'all' && row.categoria !== detailState.selectedCategory) return false;
                    if (detailState.selectedSubcategory !== 'all' && row.subcategoria !== detailState.selectedSubcategory) return false;
                    if (detailState.selectedService !== 'all' && row.servicio !== detailState.selectedService) return false;
                    if (detailState.selectedSystem !== 'all' && row.sistema !== detailState.selectedSystem) return false;
                } else {
                    if (detailState.selectedCategory !== 'all' && row.tipo !== detailState.selectedCategory) return false;
                    if (detailState.selectedSubcategory !== 'all' && row.ceco !== detailState.selectedSubcategory) return false;
                    if (detailState.selectedService !== 'all' && row.detalle !== detailState.selectedService) return false;
                }
                return true;
            });

            let activeMonths = monthsSorted;
            if (detailState.selectedMonth !== 'all') {
                activeMonths = [detailState.selectedMonth];
            } else {
                const monthsWithData = new Set(rowsFiltered.map(r => r.mes));
                activeMonths = monthsSorted.filter(m => monthsWithData.has(m));
                if (activeMonths.length === 0) activeMonths = ['ENERO', 'FEBRERO', 'MARZO', 'ABRIL'];
            }

            const serviceMap = {};
            rowsFiltered.forEach(row => {
                let key = '', serviceName = '', codServ = 0, codPpto = 0;
                if (state.currentView === 'OPEX') {
                    codServ = row.cod_servicio || 0;
                    codPpto = row.cod_presupuesto || 0;
                    serviceName = row.servicio || '-';
                    key = `${codServ} - ${codPpto} - ${serviceName}`;
                } else {
                    serviceName = row.detalle || '-';
                    key = serviceName;
                }

                if (!serviceMap[key]) {
                    serviceMap[key] = { key: key, serviceName: serviceName, codServ: codServ, codPpto: codPpto, monthly: {} };
                    activeMonths.forEach(m => serviceMap[key].monthly[m] = { ppto: 0, gastado: 0, ahorrado: 0 });
                }

                const m = row.mes;
                if (serviceMap[key].monthly[m]) {
                    serviceMap[key].monthly[m].ppto += (isPen ? row.ppto_pen : row.ppto_usd) || 0;
                    serviceMap[key].monthly[m].gastado += (isPen ? row.gastado_pen : row.gastado_usd) || 0;
                    serviceMap[key].monthly[m].ahorrado += (isPen ? row.ahorrado_pen : row.ahorrado_usd) || 0;
                }
            });

            el.detailMatrixTable.innerHTML = '';
            const thead = document.createElement('thead');
            
            let headerHtmlTop = `<tr class="matrix-header-month"><th>Descripción de Servicio</th>`;
            activeMonths.forEach(m => headerHtmlTop += `<th colspan="3">${m.charAt(0) + m.slice(1).toLowerCase()}</th>`);
            headerHtmlTop += `<th colspan="3">Total</th></tr>`;

            let headerHtmlSub = `<tr class="matrix-header-metrics"><th></th>`;
            activeMonths.forEach(() => headerHtmlSub += `<th class="matrix-col-ppto">PPTO</th><th class="matrix-col-gastado">Gastado</th><th class="matrix-col-ahorrado">Ahorrado</th>`);
            headerHtmlSub += `<th class="matrix-col-ppto">PPTO</th><th class="matrix-col-gastado">Gastado</th><th class="matrix-col-ahorrado">Ahorrado</th></tr>`;

            thead.innerHTML = headerHtmlTop + headerHtmlSub;
            el.detailMatrixTable.appendChild(thead);

            const tbody = document.createElement('tbody');
            if (Object.keys(serviceMap).length === 0) {
                tbody.innerHTML = `<tr><td colspan="${(activeMonths.length + 1) * 3 + 1}" style="text-align: center; color: var(--text-muted); padding: 20px;">No se encontraron registros.</td></tr>`;
                el.detailMatrixTable.appendChild(tbody);
                return;
            }

            const columnTotals = {};
            activeMonths.forEach(m => columnTotals[m] = { ppto: 0, gastado: 0, ahorrado: 0 });
            let grandPpto = 0, grandGastado = 0, grandAhorrado = 0;

            Object.keys(serviceMap).sort().forEach(key => {
                const service = serviceMap[key];
                const tr = document.createElement('tr');
                let rowHtml = `<td>${key}</td>`;
                let serviceTotalPpto = 0, serviceTotalGastado = 0, serviceTotalAhorrado = 0;

                activeMonths.forEach(m => {
                    const vals = service.monthly[m] || { ppto: 0, gastado: 0, ahorrado: 0 };
                    serviceTotalPpto += vals.ppto; serviceTotalGastado += vals.gastado; serviceTotalAhorrado += vals.ahorrado;
                    columnTotals[m].ppto += vals.ppto; columnTotals[m].gastado += vals.gastado; columnTotals[m].ahorrado += vals.ahorrado;

                    const ahorradoClass = vals.ahorrado < 0 ? 'matrix-val-negative' : vals.ahorrado > 0 ? 'matrix-val-positive' : '';
                    rowHtml += `
                        <td class="num-col matrix-col-ppto">${vals.ppto > 0 ? formatCellValue(vals.ppto) : '-'}</td>
                        <td class="num-col matrix-col-gastado">${vals.gastado > 0 ? formatCellValue(vals.gastado) : '-'}</td>
                        <td class="num-col matrix-col-ahorrado ${ahorradoClass}">${formatCellValue(vals.ahorrado)}</td>
                    `;
                });

                grandPpto += serviceTotalPpto; grandGastado += serviceTotalGastado; grandAhorrado += serviceTotalAhorrado;
                const rowAhorradoClass = serviceTotalAhorrado < 0 ? 'matrix-val-negative' : serviceTotalAhorrado > 0 ? 'matrix-val-positive' : '';
                rowHtml += `
                    <td class="num-col matrix-col-ppto" style="font-weight: 600;">${serviceTotalPpto > 0 ? formatCellValue(serviceTotalPpto) : '-'}</td>
                    <td class="num-col matrix-col-gastado" style="font-weight: 600;">${serviceTotalGastado > 0 ? formatCellValue(serviceTotalGastado) : '-'}</td>
                    <td class="num-col matrix-col-ahorrado ${rowAhorradoClass}" style="font-weight: 600;">${formatCellValue(serviceTotalAhorrado)}</td>
                `;
                tr.innerHTML = rowHtml;
                tbody.appendChild(tr);
            });

            const totalRow = document.createElement('tr');
            totalRow.className = 'table-row-total';
            let totalRowHtml = `<td>Total</td>`;
            activeMonths.forEach(m => {
                const tots = columnTotals[m];
                const colAhorradoClass = tots.ahorrado < 0 ? 'matrix-val-negative' : tots.ahorrado > 0 ? 'matrix-val-positive' : '';
                totalRowHtml += `
                    <td class="num-col matrix-col-ppto">${tots.ppto > 0 ? formatCellValue(tots.ppto) : '-'}</td>
                    <td class="num-col matrix-col-gastado">${tots.gastado > 0 ? formatCellValue(tots.gastado) : '-'}</td>
                    <td class="num-col matrix-col-ahorrado ${colAhorradoClass}">${formatCellValue(tots.ahorrado)}</td>
                `;
            });
            const grandAhorradoClass = grandAhorrado < 0 ? 'matrix-val-negative' : grandAhorrado > 0 ? 'matrix-val-positive' : '';
            totalRowHtml += `
                <td class="num-col matrix-col-ppto">${formatCellValue(grandPpto)}</td>
                <td class="num-col matrix-col-gastado">${formatCellValue(grandGastado)}</td>
                <td class="num-col matrix-col-ahorrado ${grandAhorradoClass}">${formatCellValue(grandAhorrado)}</td>
            `;
            totalRow.innerHTML = totalRowHtml;
            tbody.appendChild(totalRow);
            el.detailMatrixTable.appendChild(tbody);
        }

        function formatCellValue(value) {
            if (value === 0) return '0';
            const prefix = state.currency === 'PEN' ? 'S/. ' : '$ ';
            return prefix + Math.round(value).toLocaleString('en-US');
        }

        // Rates Modal
        function showExchangeRatesModal() {
            renderRatesInModal();
            el.ratesModal.classList.remove('hidden');
        }

        function renderRatesInModal() {
            el.ratesListContainer.innerHTML = '';
            const sortedRateYears = Object.keys(state.exchangeRates).sort((a,b) => b - a);
            if (sortedRateYears.length === 0) {
                el.ratesListContainer.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 10px;">No hay tipos de cambio registrados</div>';
                return;
            }
            sortedRateYears.forEach(year => {
                const rate = state.exchangeRates[year];
                const div = document.createElement('div');
                div.className = 'rate-item';
                div.innerHTML = `
                    <span class="rate-item-year">Año ${year}</span>
                    <span class="rate-item-value">S/. ${rate.toFixed(3)}</span>
                `;
                el.ratesListContainer.appendChild(div);
            });
        }

        function showLoader(show) {
            if (show) el.loader.classList.remove('hidden');
            else el.loader.classList.add('hidden');
        }
    </script>
</body>
</html>
