        // LocalStorage logic
        function saveDataToStorage() {
            try {
                localStorage.setItem('db3_raw_opex', JSON.stringify(state.rawOpex));
                localStorage.setItem('db3_raw_capex', JSON.stringify(state.rawCapex));
                localStorage.setItem('db3_years', JSON.stringify(state.years));
                localStorage.setItem('db3_rates', JSON.stringify(state.exchangeRates));
                localStorage.setItem('db3_last_updated', state.lastUpdated);
            } catch (e) {
                console.error("Local Storage Save Error:", e);
                alert("Los datos exceden el tamaño de almacenamiento del navegador. Solo los filtros principales estarán activos.");
            }
        }

        function loadDataFromStorage() {
            try {
                const opex = localStorage.getItem('db3_raw_opex');
                const capex = localStorage.getItem('db3_raw_capex');
                const years = localStorage.getItem('db3_years');
                const rates = localStorage.getItem('db3_rates');
                const updated = localStorage.getItem('db3_last_updated');
                
                if (opex) state.rawOpex = JSON.parse(opex);
                if (capex) state.rawCapex = JSON.parse(capex);
                if (years) state.years = JSON.parse(years);
                if (rates) state.exchangeRates = JSON.parse(rates);
                if (updated) state.lastUpdated = updated;
            } catch (e) {
                console.error("Local Storage Load Error:", e);
            }
        }

        function clearCache() {
            if (confirm("¿Estás seguro de que deseas borrar todos los presupuestos cargados en caché?")) {
                localStorage.clear();
                state.rawOpex = [];
                state.rawCapex = [];
                state.years = [];
                state.lastUpdated = '';
                el.updateDateLabel.textContent = 'Cargue los archivos para comenzar';
                clearAllFilters();
                alert("Caché borrada.");
                location.reload();
            }
        }

        // client-side Excel Parser using SheetJS
        async function handleFolderUpload(e) {
            const files = Array.from(e.target.files);
            const excelFiles = files.filter(f => f.name.toLowerCase().endsWith('.xlsx') || f.name.toLowerCase().endsWith('.xlsm'));
            if (excelFiles.length === 0) {
                alert("No se encontraron archivos Excel en la carpeta seleccionada. Asegúrese de que tengan la extensión .xlsx o .xlsm");
                return;
            }
            
            showLoader(true);
            let allOpex = [];
            let allCapex = [];
            let foundYears = new Set();
            
            try {
                for (const file of excelFiles) {
                    const name = file.name;
                    const match = name.match(/PPTO\s*(\d{4})/i);
                    if (!match) continue;
                    const year = parseInt(match[1]);
                    foundYears.add(year);
                    
                    const data = await readFileAsArrayBuffer(file);
                    const workbook = XLSX.read(data, {type: 'array'});
                    
                    // Read BD OPEX
                    if (workbook.SheetNames.includes("BD OPEX")) {
                        const sheet = workbook.Sheets["BD OPEX"];
                        const json = XLSX.utils.sheet_to_json(sheet, {defval: ""});
                        json.forEach(row => {
                            const mesVal = String(row['MES'] || '').trim().toUpperCase();
                            if (!MONTH_MAP[mesVal]) return;
                            
                            allOpex.push({
                                year: year,
                                cod_presupuesto: parseInt(row['Cod de Presupuesto']) || 0,
                                cod_servicio: parseInt(row['Cod de Servicio']) || 0,
                                desc_cod_servicio: String(row['Descripción Cod Servicio'] || ''),
                                servicio: String(row['Descripción del Servicio'] || ''),
                                categoria: String(row['Categoria..'] || ''),
                                subcategoria: String(row['SubCategoria..'] || ''),
                                sistema: String(row['Sistema'] || ''),
                                mes: mesVal,
                                mes_num: MONTH_MAP[mesVal],
                                
                                ppto_pen: parseFloat(row['Presupuesto']) || 0.0,
                                gastado_pen: parseFloat(row['Conformidad PEN']) || 0.0,
                                ahorrado_pen: parseFloat(row['Ahorro Real..']) || 0.0,
                                ppto_no_usado_pen: parseFloat(row['Ahorro No uso PPTO']) || 0.0,
                                
                                ppto_usd: parseFloat(row['PPTO USD']) || 0.0,
                                gastado_usd: parseFloat(row['Conformidad USD']) || 0.0,
                                ahorrado_usd: parseFloat(row['AHORRO USD']) || 0.0,
                                ppto_no_usado_usd: parseFloat(row['Ahorro No uso PPTO USD']) || 0.0,
                                
                                ahorro_proy_pen: parseFloat(row['Ahorro Proyec.']) || 0.0,
                                ahorro_proy_usd: parseFloat(row['AHORRO PROYECTADO USD']) || 0.0
                            });
                        });
                    }
                    
                    // Read BD CAPEX
                    if (workbook.SheetNames.includes("BD CAPEX")) {
                        const sheet = workbook.Sheets["BD CAPEX"];
                        const json = XLSX.utils.sheet_to_json(sheet, {defval: ""});
                        json.forEach(row => {
                            const mesVal = String(row['MES'] || '').trim().toUpperCase();
                            if (!MONTH_MAP[mesVal]) return;
                            
                            allCapex.push({
                                year: year,
                                detalle: String(row['DETALLE'] || ''),
                                tipo: String(row['TIPO'] || ''),
                                ceco: String(row['CECO'] || ''),
                                mes: mesVal,
                                mes_num: MONTH_MAP[mesVal],
                                
                                ppto_usd: parseFloat(row['INVERSIÓN $']) || 0.0,
                                gastado_usd: parseFloat(row['CONSUMIDO $']) || 0.0,
                                ahorrado_usd: parseFloat(row['AHORRO $']) || 0.0,
                                ahorro_proy_usd: parseFloat(row['AHORRO PROYECTADO']) || 0.0,
                                ppto_no_usado_usd: parseFloat(row['PPTO no USADO']) || 0.0,
                                
                                ppto_pen: parseFloat(row['INVERSIÓN PEN']) || 0.0,
                                gastado_pen: parseFloat(row['CONSUMIDO PEN']) || 0.0,
                                ahorrado_pen: parseFloat(row['AHORRO PEN']) || 0.0
                            });
                        });
                    }
                }
                
                state.rawOpex = allOpex;
                state.rawCapex = allCapex;
                state.years = Array.from(foundYears).sort();
                state.lastUpdated = new Date().toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
                
                el.updateDateLabel.textContent = `Actualizado el ${state.lastUpdated}`;
                
                saveDataToStorage();
                
                if (state.years.length > 0) {
                    state.selectedYear = String(state.years[state.years.length - 1]);
                }
                
                populateFilters();
                checkMissingExchangeRates();
                updateDashboard();
                
                alert(`Carga exitosa. Se procesaron ${allOpex.length} registros de OPEX y ${allCapex.length} de CAPEX.`);
            } catch (err) {
                console.error(err);
                alert("Error al procesar los archivos de Excel. Verifique el formato.");
            } finally {
                showLoader(false);
                el.folderUpload.value = '';
            }
        }

        function readFileAsArrayBuffer(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = (e) => resolve(e.target.result);
                reader.onerror = (e) => reject(e);
                reader.readAsArrayBuffer(file);
            });
        }

        // Populate standard filters dropdowns
        function populateFilters() {
            el.filterYear.innerHTML = '<option value="all">Todas</option>';
            el.filterCategory.innerHTML = '<option value="all">Todas</option>';
            el.filterSubcategory.innerHTML = '<option value="all">Todas</option>';

            state.years.forEach(y => el.filterYear.innerHTML += `<option value="${y}">${y}</option>`);

            const dataset = state.currentView === 'OPEX' ? state.rawOpex : state.rawCapex;
            const categories = new Set();
            const subcategories = new Set();
            
            dataset.forEach(row => {
                if (state.currentView === 'OPEX') {
                    if (row.categoria) categories.add(row.categoria);
                    if (row.subcategoria) subcategories.add(row.subcategoria);
                } else {
                    if (row.tipo) categories.add(row.tipo);
                }
            });

            Array.from(categories).sort().forEach(c => el.filterCategory.innerHTML += `<option value="${c}">${c}</option>`);
            
            if (state.currentView === 'OPEX') {
                Array.from(subcategories).sort().forEach(s => el.filterSubcategory.innerHTML += `<option value="${s}">${s}</option>`);
                el.filterSubcategoryGroup.classList.remove('hidden');
            } else {
                el.filterSubcategoryGroup.classList.add('hidden');
            }

            el.filterYear.value = state.selectedYear;
            el.filterCategory.value = state.selectedCategory;
            el.filterSubcategory.value = state.selectedSubcategory;
        }

        function checkMissingExchangeRates() {
            for (const year of state.years) {
                if (!state.exchangeRates[String(year)]) {
                    el.promptYearLabel.textContent = year;
                    el.promptYearHidden.value = year;
                    el.promptRateValue.value = '';
                    el.promptRateModal.classList.remove('hidden');
                    break;
                }
            }
        }

        async function handleAddExchangeRate(e) {
            e.preventDefault();
            const year = el.newRateYear.value;
            const rate = parseFloat(el.newRateValue.value);
            state.exchangeRates[year] = rate;
            saveDataToStorage();
            renderRatesInModal();
            el.newRateYear.value = '';
            el.newRateValue.value = '';
            updateDashboard();
        }

        async function handlePromptExchangeRate(e) {
            e.preventDefault();
            const year = el.promptYearHidden.value;
            let rate = parseFloat(el.promptRateValue.value);
            if (isNaN(rate)) {
                const prevYear = String(parseInt(year) - 1);
                rate = state.exchangeRates[prevYear] || 3.65;
            }
            state.exchangeRates[year] = rate;
            saveDataToStorage();
            el.promptRateModal.classList.add('hidden');
            checkMissingExchangeRates();
            updateDashboard();
        }

        // Toggle Currencies
        function toggleCurrency() {
            if (state.currentView === 'CAPEX') return;
            state.currency = state.currency === 'USD' ? 'PEN' : 'USD';
            el.btnCurrency.querySelector('.currency-indicator').textContent = state.currency === 'USD' ? '$' : 'S/.';
            el.dashboardTitle.textContent = `Presupuesto TI – OPEX (${state.currency})`;
            updateDashboard();
        }

        // Switch OPEX/CAPEX views
        function switchDashboardView() {
            if (state.currentView === 'OPEX') {
                state.currentView = 'CAPEX';
                state.currency = 'USD';
                el.dashboardTitle.textContent = `Presupuesto TI – CAPEX`;
                el.btnCurrency.style.opacity = '0.3';
                el.btnCurrency.style.pointerEvents = 'none';
                el.menuSwitchView.textContent = 'OPEX';
            } else {
                state.currentView = 'OPEX';
                state.currency = 'USD';
                el.btnCurrency.querySelector('.currency-indicator').textContent = '$';
                el.dashboardTitle.textContent = `Presupuesto TI – OPEX (USD)`;
                el.btnCurrency.style.opacity = '1';
                el.btnCurrency.style.pointerEvents = 'auto';
                el.menuSwitchView.textContent = 'CAPEX';
            }
            state.activeSelection = null;
            populateFilters();
            updateDashboard();
        }

        function clearAllFilters() {
            state.selectedQ = 'all';
            state.selectedMonth = 'all';
            state.selectedCategory = 'all';
            state.selectedSubcategory = 'all';
            
            el.filterQ.value = 'all';
            el.filterMonth.value = 'all';
            el.filterCategory.value = 'all';
            if (el.filterSubcategory) el.filterSubcategory.value = 'all';
            
            if (state.years.length > 0) {
                state.selectedYear = String(state.years[state.years.length - 1]);
                el.filterYear.value = state.selectedYear;
            }
            state.activeSelection = null;
            updateDashboard();
        }

        // Core render trigger
        function updateDashboard() {
            if (state.rawOpex.length === 0 && state.rawCapex.length === 0) return;
            
            const filtered = getFilteredData();
            const prevYearFiltered = getPrevYearFilteredData();
            const kpis = computeKPIs(filtered, prevYearFiltered);
            
            renderKPICards(kpis);
            renderChart(filtered);
            renderTables(filtered);
        }

        function getFilteredData() {
            const dataset = state.currentView === 'OPEX' ? state.rawOpex : state.rawCapex;
            return dataset.filter(row => {
                if (state.selectedYear !== 'all' && String(row.year) !== state.selectedYear) return false;
                if (state.selectedQ !== 'all') {
                    const q = Math.ceil(row.mes_num / 3);
                    if (String(q) !== state.selectedQ) return false;
                }
                if (state.selectedMonth !== 'all' && row.mes !== state.selectedMonth) return false;
                if (state.selectedCategory !== 'all') {
                    const compCat = state.currentView === 'OPEX' ? row.categoria : row.tipo;
                    if (compCat !== state.selectedCategory) return false;
                }
                if (state.currentView === 'OPEX' && state.selectedSubcategory !== 'all') {
                    if (row.subcategoria !== state.selectedSubcategory) return false;
                }
                return true;
            });
        }

        function getPrevYearFilteredData() {
            if (state.selectedYear === 'all') return [];
            const prevYearStr = String(parseInt(state.selectedYear) - 1);
            const dataset = state.currentView === 'OPEX' ? state.rawOpex : state.rawCapex;
            
            return dataset.filter(row => {
                if (String(row.year) !== prevYearStr) return false;
                if (state.selectedQ !== 'all') {
                    const q = Math.ceil(row.mes_num / 3);
                    if (String(q) !== state.selectedQ) return false;
                }
                if (state.selectedMonth !== 'all') {
                    const selectedMonthNum = MONTH_MAP[state.selectedMonth];
                    if (row.mes_num > selectedMonthNum) return false;
                }
                if (state.selectedCategory !== 'all') {
                    const compCat = state.currentView === 'OPEX' ? row.categoria : row.tipo;
                    if (compCat !== state.selectedCategory) return false;
                }
                if (state.currentView === 'OPEX' && state.selectedSubcategory !== 'all') {
                    if (row.subcategoria !== state.selectedSubcategory) return false;
                }
                return true;
            });
        }

        // Calculations & KPI binds
        function computeKPIs(currentData, prevData) {
            const isPen = state.currency === 'PEN';
            const sumField = (dataset, fieldPen, fieldUsd) => {
                return dataset.reduce((acc, row) => acc + (isPen ? (row[fieldPen] || 0.0) : (row[fieldUsd] || 0.0)), 0);
            };
            const sumFieldAlt = (dataset, fieldPen, fieldUsd) => {
                return dataset.reduce((acc, row) => acc + (!isPen ? (row[fieldPen] || 0.0) : (row[fieldUsd] || 0.0)), 0);
            };

            const opexCols = {
                ppto: ['ppto_pen', 'ppto_usd'],
                gastado: ['gastado_pen', 'gastado_usd'],
                ahorrado: ['ahorrado_pen', 'ahorrado_usd'],
                no_usado: ['ppto_no_usado_pen', 'ppto_no_usado_usd']
            };

            const capexCols = {
                ppto: ['ppto_pen', 'ppto_usd'],
                gastado: ['gastado_pen', 'gastado_usd'],
                ahorrado: ['ahorrado_pen', 'ahorrado_usd'],
                no_usado: ['ppto_pen', 'ppto_usd']
            };

            const cols = state.currentView === 'OPEX' ? opexCols : capexCols;

            const currentPpto = sumField(currentData, cols.ppto[0], cols.ppto[1]);
            const currentGastado = sumField(currentData, cols.gastado[0], cols.gastado[1]);
            const currentAhorrado = sumField(currentData, cols.ahorrado[0], cols.ahorrado[1]);
            
            let currentNoUsado = 0;
            if (state.currentView === 'OPEX') {
                currentNoUsado = sumField(currentData, cols.no_usado[0], cols.no_usado[1]);
            } else {
                currentNoUsado = currentData.reduce((acc, row) => acc + (row.ppto_no_usado_usd || 0.0), 0);
            }

            const altPpto = state.currentView === 'OPEX' ? sumFieldAlt(currentData, cols.ppto[0], cols.ppto[1]) : 0;
            const altGastado = state.currentView === 'OPEX' ? sumFieldAlt(currentData, cols.gastado[0], cols.gastado[1]) : 0;
            const altAhorrado = state.currentView === 'OPEX' ? sumFieldAlt(currentData, cols.ahorrado[0], cols.ahorrado[1]) : 0;
            const altNoUsado = state.currentView === 'OPEX' ? sumFieldAlt(currentData, cols.no_usado[0], cols.no_usado[1]) : 0;

            const prevPpto = sumField(prevData, cols.ppto[0], cols.ppto[1]);
            const prevGastado = sumField(prevData, cols.gastado[0], cols.gastado[1]);
            const prevAhorrado = sumField(prevData, cols.ahorrado[0], cols.ahorrado[1]);
            
            let prevNoUsado = 0;
            if (state.currentView === 'OPEX') {
                prevNoUsado = sumField(prevData, cols.no_usado[0], cols.no_usado[1]);
            } else {
                prevNoUsado = prevData.reduce((acc, row) => acc + (row.ppto_no_usado_usd || 0.0), 0);
            }

            const calcVar = (curr, prev) => {
                if (!prev || prev === 0) return null;
                return ((curr - prev) / prev) * 100;
            };

            return {
                presupuesto: { current: currentPpto, alt: altPpto, prev: prevPpto, varPct: calcVar(currentPpto, prevPpto) },
                gastado: { current: currentGastado, alt: altGastado, prev: prevGastado, varPct: calcVar(currentGastado, prevGastado), progressPct: currentPpto > 0 ? (currentGastado / currentPpto) * 100 : 0 },
                ahorrado: { current: currentAhorrado, alt: altAhorrado, prev: prevAhorrado, varPct: calcVar(currentAhorrado, prevAhorrado), savingPct: currentPpto > 0 ? (currentAhorrado / currentPpto) * 100 : 0 },
                noUsado: { current: currentNoUsado, alt: altNoUsado, prev: prevNoUsado, varPct: calcVar(currentNoUsado, prevNoUsado), noUsadoPct: currentPpto > 0 ? (currentNoUsado / currentPpto) * 100 : 0 }
            };
        }

        // Render cards DOM
        function renderKPICards(kpis) {
            const isPen = state.currency === 'PEN';
            const altCurrLabel = isPen ? 'USD' : 'PEN';
            
            el.valPresupuestado.textContent = formatCurrency(kpis.presupuesto.current, state.currency);
            if (state.currentView === 'OPEX') {
                el.subPresupuestoAlt.textContent = `Presupuesto ${altCurrLabel}: ${formatCurrency(kpis.presupuesto.alt, altCurrLabel)}`;
                el.subPresupuestoAlt.classList.remove('hidden');
            } else {
                el.subPresupuestoAlt.classList.add('hidden');
            }
            
            if (state.selectedYear !== 'all' && kpis.presupuesto.prev > 0) {
                el.subPresupuestoPrev.innerHTML = `PPTO Año Ant.: <span class="val">${formatCurrency(kpis.presupuesto.prev, state.currency)}</span> / <span class="var-pct ${getArrowClass(kpis.presupuesto.varPct)}">${formatPercentage(kpis.presupuesto.varPct, true)} ${getArrowIcon(kpis.presupuesto.varPct)}</span>`;
                el.subPresupuestoPrev.classList.remove('hidden');
            } else {
                el.subPresupuestoPrev.innerHTML = 'PPTO Año Ant.: <span class="val">--</span>';
            }

            el.valGastado.textContent = formatCurrency(kpis.gastado.current, state.currency);
            if (state.currentView === 'OPEX') {
                el.subGastadoAlt.textContent = `Gastado ${altCurrLabel}: ${formatCurrency(kpis.gastado.alt, altCurrLabel)}`;
                el.subGastadoAlt.classList.remove('hidden');
            } else {
                el.subGastadoAlt.classList.add('hidden');
            }
            
            if (state.selectedYear !== 'all' && kpis.gastado.prev > 0) {
                el.subGastadoPrev.innerHTML = `Gastado Año Ant.: <span class="val">${formatCurrency(kpis.gastado.prev, state.currency)}</span> / <span class="var-pct ${getArrowClass(kpis.gastado.varPct)}">${formatPercentage(kpis.gastado.varPct, true)} ${getArrowIcon(kpis.gastado.varPct)}</span>`;
                el.subGastadoPrev.classList.remove('hidden');
            } else {
                el.subGastadoPrev.innerHTML = 'Gastado Año Ant.: <span class="val">--</span>';
            }

            const progress = Math.min(100, Math.max(0, kpis.gastado.progressPct));
            el.pctGastado.textContent = formatPercentage(progress);
            
            const perimeter = 100.53;
            const offset = perimeter - (progress / 100) * perimeter;
            el.gastadoProgressRing.style.strokeDashoffset = offset;

            el.valAhorrado.textContent = formatCurrency(kpis.ahorrado.current, state.currency);
            if (state.currentView === 'OPEX') {
                el.subAhorradoAlt.textContent = `Ahorrado ${altCurrLabel}: ${formatCurrency(kpis.ahorrado.alt, altCurrLabel)}`;
                el.subAhorradoAlt.classList.remove('hidden');
            } else {
                el.subAhorradoAlt.classList.add('hidden');
            }
            
            if (state.selectedYear !== 'all' && kpis.ahorrado.prev > 0) {
                el.subAhorradoPrev.innerHTML = `Ahorrado Año Ant.: <span class="val">${formatCurrency(kpis.ahorrado.prev, state.currency)}</span> / <span class="var-pct ${getArrowClass(kpis.ahorrado.varPct)}">${formatPercentage(kpis.ahorrado.varPct, true)} ${getArrowIcon(kpis.ahorrado.varPct)}</span>`;
                el.subAhorradoPrev.classList.remove('hidden');
            } else {
                el.subAhorradoPrev.innerHTML = 'Ahorrado Año Ant.: <span class="val">--</span>';
            }
            
            el.pillAhorroPct.textContent = formatPercentage(kpis.ahorrado.savingPct, true);
            el.pillAhorroPct.className = 'kpi-saving-pct-pill ' + (kpis.ahorrado.savingPct >= 0 ? 'positive' : 'negative');

            if (state.currentView === 'CAPEX' && kpis.noUsado.current === 0) {
                el.valNoUsado.textContent = '-';
                el.pillNoUsadoPct.textContent = '- %';
                el.pillNoUsadoPct.className = 'kpi-saving-pct-pill';
                el.subNoUsadoAlt.classList.add('hidden');
                el.subNoUsadoPrev.innerHTML = 'PPTO no Usado Año Ant.: --';
            } else {
                el.valNoUsado.textContent = formatCurrency(kpis.noUsado.current, state.currency);
                if (state.currentView === 'OPEX') {
                    el.subNoUsadoAlt.textContent = `PPTO no Usado ${altCurrLabel}: ${formatCurrency(kpis.noUsado.alt, altCurrLabel)}`;
                    el.subNoUsadoAlt.classList.remove('hidden');
                } else {
                    el.subNoUsadoAlt.classList.add('hidden');
                }
                
                if (state.selectedYear !== 'all' && kpis.noUsado.prev > 0) {
                    el.subNoUsadoPrev.innerHTML = `PPTO no Usado Año Ant.: <span class="val">${formatCurrency(kpis.noUsado.prev, state.currency)}</span>`;
                    el.subNoUsadoPrev.classList.remove('hidden');
                } else {
                    el.subNoUsadoPrev.innerHTML = 'PPTO no Usado Año Ant.: <span class="val">--</span>';
                }
                
                el.pillNoUsadoPct.textContent = formatPercentage(kpis.noUsado.noUsadoPct, true);
                el.pillNoUsadoPct.className = 'kpi-saving-pct-pill ' + (kpis.noUsado.noUsadoPct >= 0 ? 'positive' : 'negative');
            }
        }

        // Render local Chart.js
        function renderChart(filteredData) {
            const monthsSorted = ['ENERO', 'FEBRERO', 'MARZO', 'ABRIL', 'MAYO', 'JUNIO', 'JULIO', 'AGOSTO', 'SETIEMBRE', 'OCTUBRE', 'NOVIEMBRE', 'DICIEMBRE'];
            const monthlyAgg = {};
            monthsSorted.forEach(m => monthlyAgg[m] = { ppto: 0, gastado: 0, ahorrado: 0 });

            const isPen = state.currency === 'PEN';
            filteredData.forEach(row => {
                const m = row.mes;
                if (monthlyAgg[m]) {
                    monthlyAgg[m].ppto += (isPen ? row.ppto_pen : row.ppto_usd) || 0;
                    monthlyAgg[m].gastado += (isPen ? row.gastado_pen : row.gastado_usd) || 0;
                    monthlyAgg[m].ahorrado += (isPen ? row.ahorrado_pen : row.ahorrado_usd) || 0;
                }
            });

            const activeMonths = monthsSorted.filter(m => monthlyAgg[m].ppto > 0 || monthlyAgg[m].gastado > 0 || monthlyAgg[m].ahorrado !== 0);
            const displayMonths = activeMonths.length > 0 ? activeMonths : ['ENERO', 'FEBRERO', 'MARZO', 'ABRIL'];

            const labels = displayMonths.map(m => m.charAt(0) + m.slice(1).toLowerCase());
            const dataPpto = displayMonths.map(m => monthlyAgg[m].ppto);
            const dataGastado = displayMonths.map(m => monthlyAgg[m].gastado);
            const dataAhorrado = displayMonths.map(m => monthlyAgg[m].ahorrado);

            if (monthlyChart) {
                monthlyChart.destroy();
            }

            const ctx = document.getElementById('monthly-chart').getContext('2d');
            monthlyChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Presupuestado', data: dataPpto, backgroundColor: '#8bae15', borderColor: '#8bae15', borderRadius: 4, borderWidth: 1, order: 2, barPercentage: 0.6, categoryPercentage: 0.6 },
                        { label: 'Gastado', data: dataGastado, backgroundColor: '#2e3748', borderColor: '#2e3748', borderRadius: 4, borderWidth: 1, order: 3, barPercentage: 0.6, categoryPercentage: 0.6 },
                        { label: 'Ahorrado', data: dataAhorrado, type: 'line', borderColor: '#1070e6', backgroundColor: '#1070e6', borderWidth: 3, pointBackgroundColor: '#1070e6', fill: false, tension: 0.2, order: 1 }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#9ca3af', font: { family: 'Outfit', size: 12 }, boxWidth: 12, padding: 20 } },
                        tooltip: {
                            backgroundColor: '#141a2a', titleColor: '#fff', bodyColor: '#9ca3af', borderColor: 'rgba(255, 255, 255, 0.1)', borderWidth: 1,
                            callbacks: { label: (ctx) => ` ${ctx.dataset.label}: ${formatCurrency(ctx.raw, state.currency)}` }
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#9ca3af', font: { family: 'Outfit' } } },
                        y: { grid: { color: 'rgba(255, 255, 255, 0.05)' }, ticks: { color: '#9ca3af', font: { family: 'Outfit' }, callback: (v) => v >= 1000 ? (v / 1000) + ' mil' : v } }
                    },
                    onClick: (event, elements) => {
                        if (elements.length > 0) {
                            const index = elements[0].index;
                            state.activeSelection = { type: 'month', value: displayMonths[index] };
                        }
                    }
                }
            });
        }

        // Render accordion tables
        function renderTables(filteredData) {
            if (state.currentView === 'OPEX') {
                el.leftTableTitle.textContent = "Proyectos";
                el.rightTableTitle.textContent = "Otros Servicios";
                
                const projData = filteredData.filter(row => row.categoria === "Proyectos App" || row.categoria === "Proyectos Infra y Ciberseguridad");
                renderExpandableTable(projData, el.leftTable, 'servicio');

                const otherData = filteredData.filter(row => row.categoria !== "Proyectos App" && row.categoria !== "Proyectos Infra y Ciberseguridad");
                renderExpandableTable(otherData, el.rightTable, 'subcategoria');
            } else {
                el.leftTableTitle.textContent = "Proyectos Sistemas";
                el.rightTableTitle.textContent = "Proyectos Otras Gerencias";
                
                const sysCapex = filteredData.filter(row => row.ceco === 'Sistemas');
                renderFlatTable(sysCapex, el.leftTable);
                
                const otherCapex = filteredData.filter(row => row.ceco !== 'Sistemas');
                renderFlatTable(otherCapex, el.rightTable);
            }
        }

        function renderExpandableTable(data, tableElement, childField) {
            const tbody = tableElement.querySelector('tbody');
            tbody.innerHTML = '';
            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: var(--text-muted);">Sin datos disponibles</td></tr>';
                return;
            }

            const hierarchy = {};
            data.forEach(row => {
                const cat = row.categoria || 'Otros';
                const childVal = row[childField] || '-';
                if (!hierarchy[cat]) {
                    hierarchy[cat] = { ppto: 0, gastado: 0, ahorro_proy: 0, ahorrado: 0, no_usado: 0, children: {} };
                }
                const rowPpto = (state.currency === 'PEN' ? row.ppto_pen : row.ppto_usd) || 0;
                const rowGastado = (state.currency === 'PEN' ? row.gastado_pen : row.gastado_usd) || 0;
                const rowAhorroProy = (state.currency === 'PEN' ? row.ahorro_proy_pen : row.ahorro_proy_usd) || 0;
                const rowAhorrado = (state.currency === 'PEN' ? row.ahorrado_pen : row.ahorrado_usd) || 0;
                const rowNoUsado = (state.currency === 'PEN' ? row.ppto_no_usado_pen : row.ppto_no_usado_usd) || 0;

                hierarchy[cat].ppto += rowPpto;
                hierarchy[cat].gastado += rowGastado;
                hierarchy[cat].ahorro_proy += rowAhorroProy;
                hierarchy[cat].ahorrado += rowAhorrado;
                hierarchy[cat].no_usado += rowNoUsado;

                if (!hierarchy[cat].children[childVal]) {
                    hierarchy[cat].children[childVal] = { ppto: 0, gastado: 0, ahorro_proy: 0, ahorrado: 0, no_usado: 0 };
                }
                hierarchy[cat].children[childVal].ppto += rowPpto;
                hierarchy[cat].children[childVal].gastado += rowGastado;
                hierarchy[cat].children[childVal].ahorro_proy += rowAhorroProy;
                hierarchy[cat].children[childVal].ahorrado += rowAhorrado;
                hierarchy[cat].children[childVal].no_usado += rowNoUsado;
            });

            let totalPpto = 0, totalGastado = 0, totalAhorroProy = 0, totalAhorrado = 0, totalNoUsado = 0;

            Object.keys(hierarchy).sort().forEach(cat => {
                const parent = hierarchy[cat];
                totalPpto += parent.ppto;
                totalGastado += parent.gastado;
                totalAhorroProy += parent.ahorro_proy;
                totalAhorrado += parent.ahorrado;
                totalNoUsado += parent.no_usado;

                const isExpanded = state.expandedCategories[cat] === true;
                const parentRow = document.createElement('tr');
                parentRow.className = `tree-row-parent ${isExpanded ? 'expanded' : ''}`;
                parentRow.innerHTML = `
                    <td><span class="tree-toggle-icon"><i class="fa-solid fa-chevron-right"></i></span>${cat}</td>
                    <td class="num-col">${Math.round(parent.ppto).toLocaleString()}</td>
                    <td class="num-col">${Math.round(parent.gastado).toLocaleString()}</td>
                    <td class="num-col">${Math.round(parent.ahorro_proy).toLocaleString()}</td>
                    <td class="num-col">${Math.round(parent.ahorrado).toLocaleString()}</td>
                    <td class="num-col">${Math.round(parent.no_usado).toLocaleString()}</td>
                `;

                parentRow.addEventListener('click', () => {
                    state.expandedCategories[cat] = !isExpanded;
                    state.activeSelection = { type: 'category', value: cat };
                    renderTables(data);
                });
                tbody.appendChild(parentRow);

                if (isExpanded) {
                    Object.keys(parent.children).sort().forEach(childName => {
                        const child = parent.children[childName];
                        const childRow = document.createElement('tr');
                        childRow.className = 'tree-row-child';
                        childRow.innerHTML = `
                            <td>${childName}</td>
                            <td class="num-col">${Math.round(child.ppto).toLocaleString()}</td>
                            <td class="num-col">${Math.round(child.gastado).toLocaleString()}</td>
                            <td class="num-col">${Math.round(child.ahorro_proy).toLocaleString()}</td>
                            <td class="num-col">${Math.round(child.ahorrado).toLocaleString()}</td>
                            <td class="num-col">${Math.round(child.no_usado).toLocaleString()}</td>
                        `;
                        childRow.addEventListener('click', (e) => {
                            e.stopPropagation();
                            state.activeSelection = { type: childField, value: childName, parentCat: cat };
                            tableElement.querySelectorAll('tr').forEach(r => r.classList.remove('selected-row'));
                            childRow.classList.add('selected-row');
                        });
                        tbody.appendChild(childRow);
                    });
                }
            });

            const totalRow = document.createElement('tr');
            totalRow.className = 'table-row-total';
            totalRow.innerHTML = `
                <td>TOTAL</td>
                <td class="num-col">${Math.round(totalPpto).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalGastado).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalAhorroProy).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalAhorrado).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalNoUsado).toLocaleString()}</td>
            `;
            tbody.appendChild(totalRow);
        }

        function renderFlatTable(data, tableElement) {
            const tbody = tableElement.querySelector('tbody');
            tbody.innerHTML = '';
            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: var(--text-muted);">Sin datos disponibles</td></tr>';
                return;
            }

            let totalPpto = 0, totalGastado = 0, totalAhorroProy = 0, totalAhorrado = 0, totalNoUsado = 0;
            data.forEach(row => {
                const ppto = row.ppto_usd || 0;
                const gastado = row.gastado_usd || 0;
                const ahorroProy = row.ahorro_proy_usd || 0;
                const ahorrado = row.ahorrado_usd || 0;
                const noUsado = row.ppto_no_usado_usd || 0;

                totalPpto += ppto; totalGastado += gastado; totalAhorroProy += ahorroProy; totalAhorrado += ahorrado; totalNoUsado += noUsado;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${row.detalle}</td>
                    <td class="num-col">${Math.round(ppto).toLocaleString()}</td>
                    <td class="num-col">${Math.round(gastado).toLocaleString()}</td>
                    <td class="num-col">${Math.round(ahorroProy).toLocaleString()}</td>
                    <td class="num-col">${Math.round(ahorrado).toLocaleString()}</td>
                    <td class="num-col">${Math.round(noUsado).toLocaleString()}</td>
                `;
                tr.addEventListener('click', () => {
                    state.activeSelection = { type: 'detalle', value: row.detalle };
                    tableElement.querySelectorAll('tr').forEach(r => r.classList.remove('selected-row'));
                    tr.classList.add('selected-row');
                });
                tbody.appendChild(tr);
            });

            const totalRow = document.createElement('tr');
            totalRow.className = 'table-row-total';
            totalRow.innerHTML = `
                <td>TOTAL</td>
                <td class="num-col">${Math.round(totalPpto).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalGastado).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalAhorroProy).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalAhorrado).toLocaleString()}</td>
                <td class="num-col">${Math.round(totalNoUsado).toLocaleString()}</td>
            `;
            tbody.appendChild(totalRow);
        }

