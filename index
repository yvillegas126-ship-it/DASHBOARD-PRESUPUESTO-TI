        function routeToDetailView() {
            if (state.rawOpex.length === 0 && state.rawCapex.length === 0) {
                alert("Cargue los archivos de Excel para ver el detalle.");
                return;
            }
            let dynamicName = "TODOS";
            detailState.selectedYear = state.selectedYear;
            detailState.selectedCategory = state.selectedCategory;
            detailState.selectedSubcategory = state.selectedSubcategory;
            detailState.selectedService = 'all';
            detailState.selectedSystem = 'all';
            detailState.selectedMonth = state.selectedMonth;

            if (state.activeSelection) {
                dynamicName = state.activeSelection.value.toUpperCase();
                if (state.activeSelection.type === 'month') {
                    detailState.selectedMonth = state.activeSelection.value;
                } else if (state.activeSelection.type === 'category') {
                    detailState.selectedCategory = state.activeSelection.value;
                } else if (state.activeSelection.type === 'subcategoria') {
                    detailState.selectedSubcategory = state.activeSelection.value;
                    detailState.selectedCategory = state.activeSelection.parentCat;
                } else if (state.activeSelection.type === 'servicio') {
                    detailState.selectedService = state.activeSelection.value;
                    detailState.selectedCategory = state.activeSelection.parentCat;
                } else if (state.activeSelection.type === 'detalle') {
                    detailState.selectedService = state.activeSelection.value;
                }
            } else {
                if (state.selectedCategory !== 'all') dynamicName = state.selectedCategory.toUpperCase();
                else if (state.selectedMonth !== 'all') dynamicName = state.selectedMonth.toUpperCase();
            }

            el.detailViewTitle.textContent = `DETALLE DE PRESUPUESTO - ${dynamicName}`;
            
            document.querySelector('.toolbar-section').classList.add('hidden');
            document.querySelector('.kpis-section').classList.add('hidden');
            document.querySelector('.chart-section').classList.add('hidden');
            el.dashboardTablesView.classList.add('hidden');
            el.detailViewContainer.classList.remove('hidden');

            populateDetailFilters();
            updateDetailMatrixTable();
        }

        function backToDashboard() {
            el.detailViewContainer.classList.add('hidden');
            document.querySelector('.toolbar-section').classList.remove('hidden');
            document.querySelector('.kpis-section').classList.remove('hidden');
            document.querySelector('.chart-section').classList.remove('hidden');
