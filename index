        function setupEventListeners() {
            el.filterYear.addEventListener('change', (e) => { state.selectedYear = e.target.value; updateDashboard(); });
            el.filterQ.addEventListener('change', (e) => { state.selectedQ = e.target.value; updateDashboard(); });
            el.filterMonth.addEventListener('change', (e) => { state.selectedMonth = e.target.value; updateDashboard(); });
            el.filterCategory.addEventListener('change', (e) => { state.selectedCategory = e.target.value; updateDashboard(); });
            el.filterSubcategory.addEventListener('change', (e) => { state.selectedSubcategory = e.target.value; updateDashboard(); });

            el.btnClearFilters.addEventListener('click', clearAllFilters);
            el.btnCurrency.addEventListener('click', toggleCurrency);
            el.menuSwitchView.addEventListener('click', (e) => { e.preventDefault(); switchDashboardView(); });
            
            el.btnDetailView.addEventListener('click', routeToDetailView);
            el.btnDetailBack.addEventListener('click', backToDashboard);
            
            el.btnShowRates.addEventListener('click', showExchangeRatesModal);
            el.btnCloseRatesModal.addEventListener('click', () => el.ratesModal.classList.add('hidden'));
            
