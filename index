<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Presupuesto TI - ADP 3.0</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Local JS Libraries (Offline support) -->
    <script src="xlsx.full.min.js"></script>
    <script src="chart.js"></script>
    
    <style>
        /* Modern Dashboard Stylesheet - Premium Dark Theme */
        :root {
            --bg-color: #0b0f17;
            --card-bg: rgba(20, 26, 42, 0.75);
            --card-bg-solid: #141a2a;
            --card-border: rgba(255, 255, 255, 0.07);
            --card-hover-border: rgba(255, 255, 255, 0.15);
            
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted: #6b7280;
            
            --accent-color: #8bae15; /* ADP Green Accent */
            --accent-dark: #6e8c10;
            --accent-glow: rgba(139, 174, 21, 0.25);
            
            --success-color: #10b981;
            --success-glow: rgba(16, 185, 129, 0.15);
            --danger-color: #ef4444;
            --danger-glow: rgba(239, 68, 68, 0.15);
            
            --border-radius-lg: 16px;
            --border-radius-md: 10px;
            --border-radius-sm: 6px;
            
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.15);
            --shadow-md: 0 8px 30px rgba(0, 0, 0, 0.3);
            --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.5);
            
            --font-primary: 'Outfit', sans-serif;
            --font-secondary: 'Inter', sans-serif;
        }

        /* Reset and base styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(at 10% 10%, rgba(20, 30, 50, 0.4) 0px, transparent 50%),
                radial-gradient(at 90% 90%, rgba(139, 174, 21, 0.03) 0px, transparent 50%);
            color: var(--text-primary);
            font-family: var(--font-primary);
            min-height: 100vh;
            padding: 24px;
            overflow-x: hidden;
        }

        /* Custom Scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.2);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.15);
            border-radius: var(--border-radius-sm);
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        .app-container {
            max-width: 1600px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 16px;
            border-bottom: 3px solid var(--accent-color);
            background: rgba(11, 15, 23, 0.85);
            backdrop-filter: blur(10px);
            border-radius: var(--border-radius-sm);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo-container img {
            height: 40px;
            object-fit: contain;
        }

        #dashboard-title {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: var(--text-primary);
        }

        #update-date-label {
            font-family: var(--font-secondary);
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        /* Card Box base style */
        .card-box {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--card-border);
            border-radius: var(--border-radius-lg);
            box-shadow: var(--shadow-md);
            padding: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Toolbar & Filters */
        .toolbar-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            background: rgba(20, 26, 42, 0.4);
            border: 1px solid var(--card-border);
            padding: 12px 20px;
            border-radius: var(--border-radius-md);
            backdrop-filter: blur(8px);
        }

        .filters-container {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            align-items: center;
        }

        .filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-group label {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-secondary);
            letter-spacing: 0.5px;
        }

        .filter-group select {
            background: rgba(11, 15, 23, 0.8);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            padding: 6px 12px;
            border-radius: var(--border-radius-sm);
            font-family: var(--font-secondary);
            font-size: 0.85rem;
            outline: none;
            cursor: pointer;
            min-width: 110px;
            transition: border-color 0.2s;
        }

        .filter-group select:hover, .filter-group select:focus {
            border-color: var(--accent-color);
        }

        .toolbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .tool-btn {
            background: rgba(11, 15, 23, 0.8);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            width: 38px;
            height: 38px;
            border-radius: var(--border-radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 1.05rem;
        }

        .tool-btn:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        .currency-toggle-btn {
            width: auto;
            padding: 0 12px;
            gap: 8px;
            font-weight: 700;
        }

        .currency-indicator {
            font-size: 0.95rem;
            color: var(--accent-color);
        }

        /* Menu Dropdown */
        .menu-dropdown-container {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 44px;
            background: var(--card-bg-solid);
            border: 1px solid var(--card-border);
            min-width: 120px;
            box-shadow: var(--shadow-lg);
            border-radius: var(--border-radius-sm);
            z-index: 100;
            overflow: hidden;
        }

        .dropdown-content a {
            color: var(--text-primary);
            padding: 10px 16px;
            text-decoration: none;
            display: block;
            font-family: var(--font-secondary);
            font-size: 0.9rem;
            transition: background 0.2s, color 0.2s;
            font-weight: 500;
        }

        .dropdown-content a:hover {
            background: var(--accent-color);
            color: #000;
        }

        .menu-dropdown-container:hover .dropdown-content {
            display: block;
        }

        /* KPI Grid */
        .kpis-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 16px;
        }

        .kpi-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--border-radius-lg);
            padding: 20px;
            box-shadow: var(--shadow-sm);
            display: flex;
            flex-direction: column;
            gap: 12px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--accent-color);
            opacity: 0.8;
        }

        .kpi-card:hover {
            transform: translateY(-4px);
            border-color: var(--card-hover-border);
            box-shadow: var(--shadow-md);
        }

        .kpi-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .kpi-card-icon {
            font-size: 1.25rem;
            color: var(--text-secondary);
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .kpi-card-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .kpi-card-info-trigger {
            color: var(--text-muted);
            cursor: pointer;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

        .kpi-card-info-trigger:hover {
            color: var(--text-secondary);
        }

        .kpi-card-value {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -1px;
            color: var(--text-primary);
        }

        .kpi-card-footer {
            display: flex;
            flex-direction: column;
            gap: 4px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 8px;
        }

        .kpi-subitem {
            font-family: var(--font-secondary);
            font-size: 0.8rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .kpi-subitem span.val {
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Green/Red Arrow styles */
        .arrow-up {
            color: var(--success-color);
            font-weight: 600;
        }

        .arrow-down {
            color: var(--danger-color);
            font-weight: 600;
        }

        /* Progress Ring for Gastado */
        .kpi-progress-wrapper {
            position: relative;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .progress-ring {
            transform: rotate(-90deg);
        }

        .progress-ring__circle {
            transition: stroke-dashoffset 0.35s;
            transform-origin: 50% 50%;
            stroke-dasharray: 100.53; /* 2 * PI * 16 */
            stroke-dashoffset: 100.53;
        }

        .progress-text {
            position: absolute;
            font-size: 0.65rem;
            font-family: var(--font-secondary);
            font-weight: 700;
            color: var(--text-primary);
        }

        /* Savings pill for KPI 3 and 4 */
        .kpi-saving-pct-pill {
            font-family: var(--font-secondary);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .kpi-saving-pct-pill.positive {
            background: var(--success-glow);
            border-color: rgba(16, 185, 129, 0.2);
            color: var(--success-color);
        }

        .kpi-saving-pct-pill.negative {
            background: var(--danger-glow);
            border-color: rgba(239, 68, 68, 0.2);
            color: var(--danger-color);
        }

        /* Monthly Chart */
        .chart-section {
            width: 100%;
        }

        .chart-container {
            height: 320px;
            position: relative;
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 16px;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Table Cards */
        .tables-grid-section {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 1024px) {
            .tables-grid-section {
                grid-template-columns: 1fr 1fr;
            }
        }

        .table-card {
            display: flex;
            flex-direction: column;
        }

        .table-title {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--text-primary);
            border-left: 3px solid var(--accent-color);
            padding-left: 10px;
        }

        .table-scroll-container {
            overflow-x: auto;
            width: 100%;
        }

        .dashboard-table {
            width: 100%;
            border-collapse: collapse;
            font-family: var(--font-secondary);
            font-size: 0.85rem;
            text-align: left;
        }

        .dashboard-table th {
            background: rgba(11, 15, 23, 0.6);
            color: var(--text-secondary);
            font-weight: 600;
            padding: 10px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .dashboard-table td {
            padding: 10px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            color: var(--text-primary);
        }

        .dashboard-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        /* Expandable tree table styles */
        .tree-row-parent {
            font-weight: 600;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.01);
        }

        .tree-row-parent td {
            border-bottom-color: rgba(255, 255, 255, 0.08);
        }

        .tree-row-child {
            background: rgba(0, 0, 0, 0.15);
            font-size: 0.8rem;
        }

        .tree-row-child td:first-child {
            padding-left: 28px;
            color: var(--text-secondary);
        }

        .tree-toggle-icon {
            display: inline-block;
            width: 16px;
            margin-right: 6px;
            text-align: center;
            color: var(--text-muted);
            transition: transform 0.2s;
        }

        .tree-row-parent.expanded .tree-toggle-icon {
            transform: rotate(90deg);
            color: var(--accent-color);
        }

        .table-row-total {
            font-weight: 700;
            background: rgba(11, 15, 23, 0.8) !important;
            border-top: 2px solid rgba(255, 255, 255, 0.15);
        }

        .table-row-total td {
            color: var(--text-primary) !important;
            border-bottom: none;
        }

        /* Numeric alignment */
        .num-col {
            text-align: right;
            font-variant-numeric: tabular-nums;
        }

        .selected-row {
            background: rgba(139, 174, 21, 0.15) !important;
            outline: 1px solid var(--accent-color);
        }

        /* Detail View Section */
        .detail-view-section {
            display: flex;
            flex-direction: column;
            gap: 20px;
            animation: slideUp 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .detail-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 12px;
        }

        .detail-title-group {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .detail-back-btn {
            background: var(--accent-color);
            border: none;
            color: #000;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .detail-back-btn:hover {
            background: var(--text-primary);
            transform: scale(1.1);
        }

        #detail-view-title {
            font-size: 1.25rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-filters-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            background: rgba(11, 15, 23, 0.4);
            padding: 16px;
            border-radius: var(--border-radius-md);
            border: 1px solid var(--card-border);
        }

        .detail-filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .detail-filter-group label {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-secondary);
        }

        .detail-filter-group select {
            background: rgba(11, 15, 23, 0.9);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            padding: 8px 12px;
            border-radius: var(--border-radius-sm);
            font-family: var(--font-secondary);
            font-size: 0.8rem;
            outline: none;
            cursor: pointer;
            width: 100%;
        }

        .detail-filter-group select:focus {
            border-color: var(--accent-color);
        }

        /* Detail Matrix Table */
        .detail-matrix-container {
            margin-top: 10px;
            max-height: 500px;
            overflow-y: auto;
            border: 1px solid var(--card-border);
            border-radius: var(--border-radius-md);
        }

        .matrix-table {
            width: 100%;
            border-collapse: collapse;
            font-family: var(--font-secondary);
            font-size: 0.8rem;
        }

        .matrix-table th {
            background: rgba(20, 26, 42, 0.95);
            color: var(--text-secondary);
            font-weight: 700;
            padding: 8px 10px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .matrix-table th:first-child, .matrix-table td:first-child {
            text-align: left;
            position: sticky;
            left: 0;
            z-index: 5;
            background: var(--card-bg-solid);
        }

        .matrix-table th:first-child {
            z-index: 11;
        }

        .matrix-table td {
            padding: 8px 10px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-primary);
        }

        .matrix-table tr:hover td {
            background: rgba(255, 255, 255, 0.03);
        }

        .matrix-header-month {
            border-bottom: 2px solid rgba(255, 255, 255, 0.15);
        }

        .matrix-header-metrics th {
            font-size: 0.7rem;
            padding: 4px 6px;
            font-weight: 500;
        }

        .matrix-col-ppto {
            background: rgba(255, 255, 255, 0.01);
        }

        .matrix-col-gastado {
            background: rgba(255, 255, 255, 0.02);
        }

        .matrix-col-ahorrado {
            background: rgba(139, 174, 21, 0.03);
            color: var(--accent-color) !important;
        }

        .matrix-val-negative {
            color: var(--danger-color) !important;
        }

        .matrix-val-positive {
            color: var(--success-color) !important;
        }

        /* Administrative Controls Bar */
        .admin-controls-card {
            background: rgba(20, 26, 42, 0.3);
            padding: 12px 20px;
            border-radius: var(--border-radius-md);
        }

        .admin-controls-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }

        .admin-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .admin-title i {
            color: var(--accent-color);
        }

        .admin-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .admin-btn {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            padding: 8px 16px;
            border-radius: var(--border-radius-sm);
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-family: var(--font-primary);
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.2s;
        }

        .admin-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--text-secondary);
        }

        .upload-btn {
            background: rgba(139, 174, 21, 0.1);
            border-color: rgba(139, 174, 21, 0.3);
            color: var(--accent-color);
        }

        .upload-btn:hover {
            background: rgba(139, 174, 21, 0.2);
            border-color: var(--accent-color);
        }

        .rates-btn {
            background: rgba(255, 255, 255, 0.02);
        }

        .hidden-input {
            display: none;
        }

        /* Modals */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            animation: fadeIn 0.2s ease-out;
        }

        .modal-card {
            background: var(--card-bg-solid);
            border: 1px solid var(--card-border);
            border-radius: var(--border-radius-lg);
            box-shadow: var(--shadow-lg);
            width: 90%;
            max-width: 500px;
            overflow: hidden;
            animation: scaleUp 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .modal-header h3 {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .modal-close {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            font-size: 1.2rem;
            cursor: pointer;
            transition: color 0.2s;
        }

        .modal-close:hover {
            color: var(--text-primary);
        }

        .modal-body {
            padding: 20px;
        }

        .modal-desc {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 16px;
            line-height: 1.4;
        }

        .rates-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 200px;
            overflow-y: auto;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            padding: 8px;
            border-radius: var(--border-radius-sm);
            background: rgba(0, 0, 0, 0.2);
        }

        .rate-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 12px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: var(--border-radius-sm);
            font-family: var(--font-secondary);
            font-size: 0.85rem;
        }

        .rate-item-year {
            font-weight: 600;
        }

        .rate-item-value {
            color: var(--accent-color);
            font-weight: 600;
        }

        .rates-form h4 {
            font-size: 0.9rem;
            margin-bottom: 10px;
            color: var(--text-secondary);
            font-weight: 600;
        }

        .form-row {
            display: flex;
