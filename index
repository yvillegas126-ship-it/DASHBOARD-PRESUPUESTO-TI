        let monthlyChart = null;

        // Formatter Helpers
        function formatCurrency(amount, currencyCode) {
            if (amount === null || amount === undefined || isNaN(amount)) return '-';
            const prefix = currencyCode === 'PEN' ? 'S/. ' : '$ ';
            return prefix + Math.round(amount).toLocaleString('en-US');
        }

        function formatPercentage(value, showPlus = false) {
            if (value === null || value === undefined || isNaN(value) || !isFinite(value)) return '--';
            const rounded = Math.round(value);
            const sign = showPlus && rounded > 0 ? '+' : '';
            return `${sign}${rounded}%`;
        }

        function getArrowIcon(variation) {
            if (variation === null || variation === undefined || isNaN(variation) || !isFinite(variation)) return '';
            return variation > 0 ? '<i class="fa-solid fa-arrow-up arrow-up"></i>' : variation < 0 ? '<i class="fa-solid fa-arrow-down arrow-down"></i>' : '';
        }

        function getArrowClass(variation) {
            if (variation === null || variation === undefined || isNaN(variation) || !isFinite(variation)) return '';
            return variation > 0 ? 'arrow-up' : variation < 0 ? 'arrow-down' : '';
        }

