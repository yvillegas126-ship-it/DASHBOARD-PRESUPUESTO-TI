            el.detailFilterCategory.addEventListener('change', onDetailFilterChange);
            el.detailFilterSubcategory.addEventListener('change', onDetailFilterChange);
            el.detailFilterService.addEventListener('change', onDetailFilterChange);
            el.detailFilterSystem.addEventListener('change', onDetailFilterChange);
            el.detailFilterMonth.addEventListener('change', onDetailFilterChange);
